{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "outDir": ".ttest",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] },
    "noEmit": false,
    "noEmitOnError": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "lib/server/database.ts",
    "lib/server/migrations.ts",
    "lib/server/money.ts",
    "lib/server/auth.ts",
    "lib/server/pricing-engine.ts",
    "lib/server/services/policy.ts",
    "lib/server/services/tax.ts",
    "lib/server/services/escalation.ts",
    "lib/server/services/sequence.ts",
    "lib/server/services/order.ts",
    "lib/server/services/invoice.ts",
    "lib/server/services/invoice-template.ts",
    "lib/server/services/pdf.ts",
    "lib/server/services/payment.ts",
    "lib/server/services/dunning.ts",
    "lib/server/services/production.ts",
    "lib/server/services/client-import.ts",
    "lib/server/services/templates.ts",
    "lib/server/services/outbox.ts",
    "lib/server/services/xlsx-reader.ts",
    "lib/server/services/sheet-ingest.ts",
    "lib/server/services/triggers.ts",
    "lib/server/services/demand.ts",
    "lib/server/services/demand-extraction.ts"
  ]
}
